// =============================================================================
// NIRI CONFIGURATION - MONOCHROME & DEEP BLUE
// =============================================================================

// -----------------------------------------------------
// Monitors
// -----------------------------------------------------
output "eDP-1" {
    mode "1920x1080@165"
    scale 1.0
}

// -----------------------------------------------------
// Input
// -----------------------------------------------------
input {
    keyboard {
        xkb {
            layout "us"
        }
    }
    touchpad {
        tap
        natural-scroll
    }
    focus-follows-mouse
}

// -----------------------------------------------------
// Autostart
// -----------------------------------------------------
spawn-at-startup "uwsm" "app" "--" "swww-daemon"
spawn-at-startup "uwsm" "app" "--" "waybar"
spawn-at-startup "uwsm" "app" "--" "swaync"
spawn-at-startup "uwsm" "app" "--" "swayosd-server"
spawn-at-startup "uwsm" "app" "--" "hypridle"

// Wallpaper
spawn-sh-at-startup "sleep 0.5 && swww img ~/Pictures/wallpaper/1.jpg --transition-type fade --transition-step 30 --transition-fps 165"

// -----------------------------------------------------
// Look and Feel (Blue Glow & Borders)
// -----------------------------------------------------
layout {
    // Matches the spacing we used in Waybar (12px)
    gaps 12

    center-focused-column "never"

    preset-column-widths {
        proportion 0.333
        proportion 0.5
        proportion 0.667
    }

    default-column-width { proportion 0.5; }

    // THEME MATCH: The "Glow" Effect
    // This mimics the 'box-shadow' from your Waybar style.css
    focus-ring {
        width 4
        active-color "#5294e266" // Blue with ~40% opacity
        inactive-color "transparent"
    }

    // THEME MATCH: The Physical Border
    // Matches the 'border: 1px solid' from Waybar
    border {
        width 1 
        active-color "#5294e2"   // Sharp Deep Blue
        inactive-color "#333333" // Dark Grey (Inactive)
    }
}

animations {
    slowdown 1.0
}

// -----------------------------------------------------
// Keybindings
// -----------------------------------------------------
binds {
    // --- Core Applications ---
    Mod+Return { spawn "uwsm" "app" "--" "kitty"; }
    Mod+T      { spawn "uwsm" "app" "--" "kitty"; }
    Mod+B      { spawn "uwsm" "app" "--" "zen"; }
    Mod+E      { spawn "uwsm" "app" "--" "thunar"; }
    Mod+D      { spawn "uwsm" "app" "--" "fuzzel"; }

    // --- Session & Notifications ---
    Mod+Q      { close-window; }
    Mod+M      { spawn "uwsm" "app" "--" "wlogout"; }
    Mod+L      { spawn "uwsm" "app" "--" "hyprlock"; }
    Mod+N      { spawn "swaync-client" "-t" "-sw"; }

    // --- Screenshot ---
    Mod+Shift+S { spawn-sh "grim -g \"$(slurp)\" -t ppm - | satty --filename - --fullscreen --output-filename ~/Pictures/Screenshots/satty-$(date +%Y%m%d-%H%M%S).png"; }

    // --- Window Navigation ---
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }
    
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    
    Mod+Comma  { consume-window-into-column; } 
    Mod+Period { expel-window-from-column; }    
    
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+V { toggle-window-floating; }
    Mod+C { center-column; }

    Mod+Alt+1 { spawn "sh" "-c" "swww img ~/Pictures/wallpaper/1.jpg --transition-type fade --transition-step 30 --transition-fps 165"; }
    Mod+Alt+2 { spawn "sh" "-c" "swww img ~/Pictures/wallpaper/2.jpg --transition-type fade --transition-step 30 --transition-fps 165"; }
    Mod+Alt+3 { spawn "sh" "-c" "swww img ~/Pictures/wallpaper/3.jpg --transition-type fade --transition-step 30 --transition-fps 165"; }
    Mod+Alt+4 { spawn "sh" "-c" "swww img ~/Pictures/wallpaper/4.jpg --transition-type fade --transition-step 30 --transition-fps 165"; }
    Mod+Alt+5 { spawn "sh" "-c" "swww img ~/Pictures/wallpaper/1.png --transition-type fade --transition-step 30 --transition-fps 165"; }

    // --- Workspaces ---
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    // --- Mouse Scroll ---
    Mod+WheelScrollDown { focus-workspace-down; }
    Mod+WheelScrollUp   { focus-workspace-up; }
    Mod+Shift+WheelScrollDown { focus-column-right; }
    Mod+Shift+WheelScrollUp   { focus-column-left; }

    // --- Hardware Controls ---
    XF86AudioRaiseVolume { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute        { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    
    XF86MonBrightnessUp   { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown { spawn "swayosd-client" "--brightness" "lower"; }
}

// -----------------------------------------------------
// Window Rules
// -----------------------------------------------------
window-rule {
    match app-id="thunar"
    default-column-width { proportion 0.4; }
}

window-rule {
    draw-border-with-background false
    geometry-corner-radius 12
    clip-to-geometry true
}

// Dim inactive windows slightly to make the Blue Border pop
window-rule {
    match is-active=false
    opacity 0.85
}
